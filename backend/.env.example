# Copy to .env and fill in
APP_NAME=Читальня
ENV=development
SECRET_KEY=change-me-to-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# SQLite for dev; swap to postgres://user:pass@host/db in prod
DATABASE_URL=postgresql://chytalnya:chytalnya_dev@localhost:5432/chytalnya

# CORS
FRONTEND_ORIGIN=http://localhost:5173

# Gmail SMTP (use an App Password, not regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=your-gmail@gmail.com

# Frontend URL used in email reset links
PUBLIC_FRONTEND_URL=http://localhost:5173

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_dummy
STRIPE_PRICE_ID_PREMIUM=price_dummy

# Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=200

# booknet.ua periodic scraper
# Get this from DevTools → Application → Cookies → litera-frontend on booknet.ua (while logged in)
BOOKNET_SESSION_COOKIE=fdd285a3d828bbf5ee50293024606439
BOOKNET_BOOKS_PER_RUN=5
BOOKNET_INTERVAL_MINUTES=30
